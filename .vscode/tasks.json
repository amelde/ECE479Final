{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build SPA subsystem",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/nologo",
                "/Fe${workspaceFolder}\\SPA\\SPA.exe",
                "${workspaceFolder}\\SPA\\main.cpp",
                "${workspaceFolder}\\SPA\\SPASystem.cpp",
                "${workspaceFolder}\\SPA\\Beverage.cpp",
                "${workspaceFolder}\\SPA\\Rule.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\SPA"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds only the SPA subsystem."
        },
        {
            "type": "cppbuild",
            "label": "Build Route Planner - Dijkstra",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/nologo",
                "/I${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\include",
                "/Fe${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\routing_dijkstra.exe",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\main.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\src\\Graph.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\src\\Robot.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra\\src\\Planner.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_Djikstra"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "Builds only the Dijkstra route planner subsystem."
        },
        {
            "type": "cppbuild",
            "label": "Build Route Planner - AStar",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/std:c++17",
                "/nologo",
                "/I${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\include",
                "/Fe${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\routing_astar.exe",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\main.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\src\\Graph.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\src\\Robot.cpp",
                "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar\\src\\Planner.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\Route and Fleet Planner\\PartA_Routing_AStar"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "Builds only the A* route planner subsystem."
        }
    ],
    "version": "2.0.0"
}
